# =============================================================================
# TeacherHelper — zmienne środowiskowe backendu
#
# WAŻNE: aplikacja wczytuje plik .env z KATALOGU GŁÓWNEGO REPOZYTORIUM
# (np. TeacherHelper/.env — ten sam poziom co foldery backend/ i frontend/),
# a NIE z backend/.env. Skopiuj więc ten plik jako ../.env albo po prostu
# utwórz .env w korzeniu projektu i wklej stąd potrzebne linie.
#
# Po zmianach zrestartuj serwer (uvicorn).
# =============================================================================

# ---------- PostgreSQL (wymagane) ----------
# Musi działać baza przed startem API. Dostosuj użytkownika, hasło, nazwę bazy i port.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/teacher
DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@localhost:5432/teacher

# ---------- JWT (wymagane w praktyce) ----------
# W produkcji: długi losowy ciąg (np. openssl rand -hex 32).
JWT_SECRET=zmien-na-losowy-ciag-min-32-znaki

# ---------- LLM — OpenRouter (jeden klucz; model ustawiasz osobno dla każdej ścieżki) ----------
# Bez OPENROUTER_API_KEY czat i moduły na OpenRouter nie zadziałają (możesz użyć stubów
# tylko w dev, jeśli tak skonfigurujesz projekt — domyślnie oczekiwany jest klucz).
# ---------- xAI (Grok) — mowa → tekst w Asystencie (Speech-to-Text); klucz z https://console.x.ai ----------
XAI_API_KEY=
# Opcjonalnie inny klaster / URL API:
# XAI_BASE_URL=https://api.x.ai/v1

OPENROUTER_API_KEY=
# Orchestrator / główny czat:
OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview
# Moduły (scenariusz, muzyka — część tekstowa LLM, wiersz, itd.):
OPENROUTER_MODULE_MODEL=google/gemini-3-flash-preview
# Obrazy — wyłącznie OpenRouter (Nano Banana / Nano Banana 2; chat/completions + modalities).
# Nano Banana 2 (domyślnie): google/gemini-3.1-flash-image-preview
# Nano Banana (2.5 Flash Image):     google/gemini-2.5-flash-image
OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image-preview
# Timeout HTTP (s) oraz opcjonalny rozmiar wyjścia dla modeli Gemini Image (1K / 2K / 4K); puste = bez pola image_size
OPENROUTER_IMAGE_TIMEOUT_SECONDS=120
OPENROUTER_IMAGE_SIZE=1K
# Ile maks. ilustracji wstawiać do jednego pliku PPTX (generate_presentation, kolejność slajdów; 0 = bez osadzania; max 10)
# PRESENTATION_MAX_EMBEDDED_IMAGES=10
# Muzyka — Lyria (to samo API co czat, inny model; SSE audio):
OPENROUTER_MUSIC_ENABLED=true
OPENROUTER_MUSIC_MODEL=google/lyria-3-pro-preview
OPENROUTER_MUSIC_TIMEOUT_SECONDS=300
# Ile osobnych utworów zlecać każdemu z dostawców (KIE + Lyria) przy jednym generate_music (max 5):
MUSIC_VARIANTS_PER_PROVIDER=2

# ---------- Wyszukiwanie w internecie (asystent: narzędzie search_web, Tavily) ----------
# Bez TAVILY_API_KEY narzędzie zwróci komunikat — opracowania można nadal generować z biblioteki lub ogólnej wiedzy modelu.
# TAVILY_API_KEY=
# Opcjonalnie 1–15 wyników na zapytanie:
# WEB_SEARCH_MAX_RESULTS=5

# ---------- Embeddingi (indeks / Qdrant) ----------
# Domyślnie EMBEDDINGS_BACKEND=auto: jeśli jest OPENAI_API_KEY — używa api.openai.com; jeśli nie — OPENROUTER_API_KEY.
# Przy złym / wygasłym kluczu OpenAI (HTTP 401) w trybie auto, jednorazowo użyty zostanie OpenRouter (ten sam co czat).
# Wymuszanie: openrouter | openai (tylko dany klucz) | auto
EMBEDDINGS_BACKEND=auto
# Bezpośrednio OpenAI (opcjonalnie, gdy masz osobny klucz od platform.openai.com):
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Model na OpenRouter — lista: https://openrouter.ai/models?output_modalities=embeddings
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIM=1536

# ---------- Qdrant (wyszukiwanie wektorowe; musi działać instancja pod tym URL) ----------
QDRANT_URL=http://localhost:6333

# ---------- Redis (rate limiting; musi działać serwer Redis) ----------
REDIS_URL=redis://localhost:6379/0

# ---------- Pliki użytkownika (katalog na dysku) ----------
# Ścieżka względna jest względem katalogu roboczego procesu (zwykle backend/ przy uvicorn).
STORAGE_ROOT=./data/storage

# ---------- Port i host API (gdy uruchamiasz: python -m teacher_helper.main) ----------
# Frontend w dev domyślnie proxy na http://127.0.0.1:8080 — zadbaj, żeby poniższy port
# zgadzał się z BACKEND_INTERNAL_URL we frontendzie/.env
# UVICORN_HOST=0.0.0.0
# UVICORN_PORT=8080
# UVICORN_RELOAD=1

# ---------- OpenAPI (Swagger / Redoc) ----------
# Na produkcji często wyłącza się dokumentację: OPENAPI_DOCS=false
# OPENAPI_DOCS=true

# =============================================================================
# Opcjonalne — odkomentuj, gdy potrzebujesz
# =============================================================================

# --- DALL-E (ignorowane przez backend — grafika tylko OpenRouter; możesz usunąć z .env) ---
# DALLE_API_KEY=
# DALLE_MODEL=dall-e-3

# --- KIE.ai — generacja muzyki (Suno API, POST /api/v1/generate) ---
# Dokumentacja: https://docs.kie.ai/suno-api/generate-music
# Bez KIE_API_KEY moduł „muzyka” zapisuje tylko plik TXT z promptem od LLM (jak dotychczas).
# KIE_API_KEY=
# KIE_API_BASE_URL=https://api.kie.ai
# KIE_MUSIC_MODEL=V4_5ALL
# callBackUrl jest WYMAGANY przez API — publiczny HTTPS, na który KIE wyśle POST (np. tunel ngrok → lokalny backend):
# KIE_MUSIC_CALLBACK_URL=https://abcd-1234.ngrok-free.app/v1/webhooks/kie/music
# Opcjonalnie klucz HMAC z https://kie.ai/settings — wymuszona weryfikacja nagłówków X-Webhook-* na powyższym endpoincie:
# KIE_WEBHOOK_HMAC_KEY=
# true = customMode (style, title, dłuższy prompt); false = uproszczony tryb (tylko prompt do 500 znaków):
# KIE_MUSIC_CUSTOM_MODE=true
# Oczekiwanie na status SUCCESS i pobranie MP3 (GET record-info). 0 = tylko .txt + taskId:
# KIE_MUSIC_POLL_TIMEOUT_SECONDS=120
# KIE_MUSIC_POLL_INTERVAL_SECONDS=1
# KIE_MUSIC_NEGATIVE_TAGS=
# KIE_MUSIC_VOCAL_GENDER=m
# KIE_MUSIC_STYLE_WEIGHT=0.65
# KIE_MUSIC_WEIRDNESS_CONSTRAINT=0.65
# KIE_MUSIC_AUDIO_WEIGHT=0.65
# KIE_MUSIC_PERSONA_ID=
# KIE_MUSIC_PERSONA_MODEL=

# --- ElevenLabs — krótkie SFX / odgłosy (POST /v1/sound/generate) ---
# https://elevenlabs.io/docs/api-reference/text-to-sound-effects/convert
# Bez ELEVENLABS_API_KEY endpoint SFX w HTTP zwróci 503; orchestrator zasygnalizuje brak w czacie.
# ELEVENLABS_API_KEY=
# ELEVENLABS_SOUND_MODEL_ID=eleven_text_to_sound_v2
# Jako parametr output_format w API, np. mp3_44100_128, mp3_44100_96 (zob. dokumentację):
# ELEVENLABS_SOUND_OUTPUT_FORMAT=mp3_44100_128
# ELEVENLABS_SOUND_TIMEOUT_SECONDS=90
# Maks. długość jednego SFX w sekundach (1–30):
# ELEVENLABS_SOUND_MAX_DURATION_SECONDS=30
# 0.0–1.0 (domyślnie 0.3):
# ELEVENLABS_SOUND_PROMPT_INFLUENCE=0.3
# Gdy w opisie wykryto np. polski — przed wysyłką do ElevenLabs krótkie tłumaczenie na EN (OpenRouter; wymaga OPENROUTER_API_KEY):
# ELEVENLABS_SFX_TRANSLATE_TO_ENGLISH=true
# ELEVENLABS_SFX_TRANSLATE_TIMEOUT_SECONDS=25
# ELEVENLABS_SFX_TRANSLATE_MAX_TOKENS=220
# Pusty = OPENROUTER_MODULE_MODEL
# ELEVENLABS_SFX_TRANSLATE_MODEL=

# --- Admin API + spójność z frontendem ---
# Jeśli ustawisz ADMIN_API_KEY, klient admina w przeglądarce powinien mieć ten sam sekret
# w pliku frontend/.env jako VITE_ADMIN_API_KEY (nagłówek X-Admin-Key).
# ADMIN_API_KEY=

# --- Konto administratora (migracja Alembic 007) ---
# Przy pierwszym `alembic upgrade head` tworzony jest użytkownik z rolą admin (JWT + endpointy /v1/admin/*).
# Ustaw hasło przed migracją na produkcji. Pominięcie seeda: SKIP_ADMIN_SEED=1
# ADMIN_SEED_EMAIL=admin@example.com
# ADMIN_SEED_PASSWORD=ChangeMeAdmin123!
# ADMIN_SEED_DISPLAY_NAME=Administrator
# SKIP_ADMIN_SEED=0

# --- Limity zużycia LLM (dzień UTC) ---
# LLM_DAILY_TOKEN_SOFT_LIMIT=
# LLM_DAILY_TOKEN_HARD_LIMIT=
# Domyślny dzienny limit tokenów LLM (UTC) na użytkownika, gdy w bazie brak własnego limitu (POST /v1/chat).
# W panelu admina: 0 = brak limitu per konto (tylko LLM_DAILY_TOKEN_* z .env).
# DEFAULT_USER_LLM_DAILY_TOKEN_LIMIT=25000

# --- Długie rozmowy — zwijanie kontekstu (podsumowanie starszej części wątku) ---
# CHAT_SUMMARY_ENABLED=true
# Ostatnie tury (user+asystent) zostają dosłownie; starsze trafiają do skrótu w conversations.extra.
# CHAT_SUMMARY_RECENT_TURNS=14
# Próg szacunku znaków surowej historii — powyżej włącza zwijanie / mocniejsze skracanie ogona.
# CHAT_CONTEXT_MAX_CHARS=45000
# Maks. wiadomości przekazywanych do orchestratora po ewentualnym skrócie (pierwsza może być syntetycznym skrótem).
# CHAT_ORCHESTRATOR_MAX_MESSAGES=36
# Opcjonalnie inny / tańszy model tylko do podsumowań (puste = OPENROUTER_MODEL):
# OPENROUTER_SUMMARY_MODEL=
# OPENROUTER_SUMMARY_MAX_COMPLETION_TOKENS=2048

# --- Domyślny rate limit (żądania/min na użytkownika, gdy brak nadpisania) ---
# DEFAULT_RATE_LIMIT_RPM=100

# --- Langfuse (zewnętrzny monitoring generacji) ---
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# --- Alerty (np. Slack / Discord przy przekroczeniu limitów) ---
# ALERT_WEBHOOK_URL=

# --- CORS (np. lista originów rozdzielona przecinkami; * = dowolny origin) ---
# CORS_ORIGINS=*

# --- Tryb debug ---
# DEBUG=false
