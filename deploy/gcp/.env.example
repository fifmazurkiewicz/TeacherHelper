# =============================================================================
# deploy/gcp/.env — Ścieżka A (Cloud SQL + redis + backend + frontend w Compose)
# Użycie: cp .env.example .env && chmod 600 .env
#
# Źródło prawdy dla nazw i domyślnych wartości: backend/teacher_helper/config.py
# (zmienne środowiskowe WIELKIMI_LITERAMI, zgodne z polami Pydantic).
#
# Docker: compose wstrzykuje ten plik jako zmienne środowiskowe kontenera backendu.
# W obrazie NIE ma pliku /app/.env — aplikacja musi dostać wszystko stąd (albo z env).
# Rozszerzone komentarze dev: backend/.env.example
# =============================================================================

# -----------------------------------------------------------------------------
# Wymagane / krytyczne na produkcji (bez tego: błąd DB, brak LLM, zły CORS itd.)
# -----------------------------------------------------------------------------

DATABASE_URL=postgresql+asyncpg://teacherhelper:TWOJE_HASLO@PUBLICZNY_IP_CLOUD_SQL:5432/teacherhelper
DATABASE_URL_SYNC=postgresql+psycopg://teacherhelper:TWOJE_HASLO@PUBLICZNY_IP_CLOUD_SQL:5432/teacherhelper

REDIS_URL=redis://redis:6379/0

# Qdrant Cloud (panel https://cloud.qdrant.io) — URL z portem :6333 + klucz
QDRANT_URL=https://TWOJ-KLASTER.cloud.qdrant.io:6333
QDRANT_API_KEY=twoj-klucz-z-qdrant-cloud
# Opcjonalnie inna kolekcja niż domyślna:
# QDRANT_COLLECTION=file_chunks

# Min. 32 znaki losowe; np. openssl rand -hex 32
JWT_SECRET=wygeneruj-openssl-rand-hex-32

# Czat, moduły, grafika (OpenRouter) — bez tego LLM nie działa
OPENROUTER_API_KEY=sk-or-v1-...

# Wyłącz Swagger/Redoc na świecie
OPENAPI_DOCS=false

# Logi: na produkcji zostaw false lub nie ustawiaj
DEBUG=false

# Musi dokładanie odpowiadać originowi z paska przeglądarki (scheme+host, bez końcowego /).
# Wiele wartości: przecinek, bez spacji wokół przecinka.
CORS_ORIGINS=https://twoja-domena.example.com,https://teacherhelper.duckdns.org

# Ścieżka musi być zgodna z wolumenem w docker-compose (backend_storage → /app/data/storage)
STORAGE_ROOT=/app/data/storage

# -----------------------------------------------------------------------------
# Konto administratora po migracji Alembic (007) — czyta os.environ, nie Settings
# -----------------------------------------------------------------------------

ADMIN_SEED_EMAIL=admin@local.test
ADMIN_SEED_PASSWORD=wygeneruj-silne-haslo
# ADMIN_SEED_DISPLAY_NAME=Administrator
# Pominięcie utworzenia admina przy migracji: 1 | true | yes
# SKIP_ADMIN_SEED=0

# -----------------------------------------------------------------------------
# Embeddingi (indeks plików / Qdrant) — domyślnie EMBEDDINGS_BACKEND=auto:
# bez OPENAI_API_KEY użyje OpenRouter, jeśli jest OPENROUTER_API_KEY
# -----------------------------------------------------------------------------

# EMBEDDINGS_BACKEND=auto
# OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
# EMBEDDING_DIM=1536

# -----------------------------------------------------------------------------
# OpenRouter — opcjonalne nadpisania modeli i limitów (domyślne w config.py)
# -----------------------------------------------------------------------------

# OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview
# OPENROUTER_MODULE_MODEL=google/gemini-3-flash-preview
# OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image-preview
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Często wymagane przez OpenRouter (ranking): URL Twojej aplikacji
# OPENROUTER_HTTP_REFERER=https://twoja-domena.example.com
# OPENROUTER_MAX_COMPLETION_TOKENS=8192
# OPENROUTER_MODULE_MAX_COMPLETION_TOKENS=16384
# OPENROUTER_IMAGE_TIMEOUT_SECONDS=120
# OPENROUTER_IMAGE_SIZE=1K
# OPENROUTER_MUSIC_ENABLED=true
# OPENROUTER_MUSIC_MODEL=google/lyria-3-pro-preview
# OPENROUTER_MUSIC_TIMEOUT_SECONDS=300
# MUSIC_VARIANTS_PER_PROVIDER=2

# -----------------------------------------------------------------------------
# Integracje zewnętrzne (wszystkie opcjonalne — patrz backend/.env.example)
# -----------------------------------------------------------------------------

# --- xAI (Grok) — transkrypcja mowy w asystencie
# XAI_API_KEY=
# XAI_BASE_URL=https://api.x.ai/v1

# --- Tavily — wyszukiwanie w sieci (narzędzie w czacie)
# TAVILY_API_KEY=
# WEB_SEARCH_MAX_RESULTS=5

# --- KIE.ai — muzyka; callback musi być publicznym HTTPS widocznym dla KIE
# KIE_API_KEY=
# KIE_MUSIC_CALLBACK_URL=https://twoja-domena.example.com/th-api/v1/webhooks/kie/music
# KIE_WEBHOOK_HMAC_KEY=
# KIE_API_BASE_URL=https://api.kie.ai
# KIE_MUSIC_MODEL=V4_5ALL
# (KIE_MUSIC_* — pełna lista w backend/.env.example)

# --- Replicate — krótkie efekty dźwiękowe
# REPLICATE_API_KEY=

# --- Panel admina: nagłówek X-Admin-Key
# Uwaga: jeśli budujesz frontend w Dockerze bez VITE_ADMIN_API_KEY, przeglądarka
# nie wyśle klucza — trzeba dodać build-arg do frontend/Dockerfile + compose albo
# przebudować frontend z tą zmienną. Szczegóły: frontend/.env.example
# ADMIN_API_KEY=

# --- Langfuse, alerty, limity dzienne LLM, zwijanie czatu, rate limit
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
# ALERT_WEBHOOK_URL=
# LLM_DAILY_TOKEN_SOFT_LIMIT=
# LLM_DAILY_TOKEN_HARD_LIMIT=
# DEFAULT_USER_LLM_DAILY_TOKEN_LIMIT=25000
# CHAT_SUMMARY_ENABLED=true
# CHAT_SUMMARY_RECENT_TURNS=14
# CHAT_CONTEXT_MAX_CHARS=45000
# CHAT_ORCHESTRATOR_MAX_MESSAGES=36
# OPENROUTER_SUMMARY_MODEL=
# OPENROUTER_SUMMARY_MAX_COMPLETION_TOKENS=2048
# DEFAULT_RATE_LIMIT_RPM=100

# --- JWT / potwierdzanie destrukcyjnych operacji
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_HOURS=168
# REQUIRE_RESOURCE_CONFIRMATION=true
# CONFIRMATION_TOKEN_EXPIRE_MINUTES=15

# --- Nieużywane w bieżącym kodzie (grafika tylko OpenRouter); można pominąć
# DALLE_API_KEY=
