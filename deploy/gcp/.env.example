# Skopiuj do .env w deploy/gcp/ (Ścieżka A — baza: Cloud SQL).
# chmod 600 .env
#
# Qdrant Cloud (darmowy klaster): w panelu https://cloud.qdrant.io skopiuj Cluster URL
# (np. https://xxxx-xxxx.us-east.aws.cloud.qdrant.io:6333) oraz API Key.

# Cloud SQL (zarządzana) — najprościej: Public IP instancji + Authorized networks (IP VM /32).
# USER/HASLO/NAZWA_BAZY z zakładek Users + Databases w karcie instancji SQL.
DATABASE_URL=postgresql+asyncpg://teacherhelper:TWOJE_HASLO@PUBLICZNY_IP_CLOUD_SQL:5432/teacherhelper
DATABASE_URL_SYNC=postgresql+psycopg://teacherhelper:TWOJE_HASLO@PUBLICZNY_IP_CLOUD_SQL:5432/teacherhelper
# Alternatywa: Cloud SQL Auth Proxy na VM → wtedy host 127.0.0.1:5432 zamiast PUBLICZNY_IP_CLOUD_SQL.
REDIS_URL=redis://redis:6379/0
QDRANT_URL=https://TWOJ-KLASTER.cloud.qdrant.io:6333
QDRANT_API_KEY=twoj-klucz-z-qdrant-cloud

JWT_SECRET=wygeneruj-openssl-rand-hex-32
OPENROUTER_API_KEY=sk-or-...
OPENAPI_DOCS=false
CORS_ORIGINS=https://twoja-domena.example.com   https://teacherhelper.duckdns.org
STORAGE_ROOT=/app/data/storage
ADMIN_SEED_EMAIL=admin@local.test
ADMIN_SEED_PASSWORD=wygeneruj-silne-haslo
