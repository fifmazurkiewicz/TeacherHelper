{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend API",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/backend/run_dev.py",
      "cwd": "${workspaceFolder}/backend",
      "python": "${workspaceFolder}/backend/.venv/Scripts/python.exe",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "UVICORN_HOST": "127.0.0.1",
        "UVICORN_PORT": "8080",
        "UVICORN_RELOAD": "0"
      }
    },
    {
      "name": "Frontend Vite",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/frontend",
      "console": "integratedTerminal"
    }
  ]
}
