KIE_API_KEY=
KIE_MUSIC_CALLBACK_URL=https://example.com/webhook
KIE_API_BASE_URL=https://api.kie.ai
KIE_MUSIC_POLL_INTERVAL_SECONDS=1.0

WAVESPEED_API_KEY=
WAVESPEED_API_BASE_URL=https://api.wavespeed.ai

# OpenRouter — Lyria (chat/completions, możliwych wiele modeli) + Seedance 1.5 Pro (POST /videos)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Opcjonalnie (OpenRouter leaderboard / limity)
OPENROUTER_HTTP_REFERER=

# ElevenLabs — Music API (POST /v1/music); opcjonalne, tylko gdy chcesz uruchamiać Eleven Music w benchmarku
ELEVENLABS_API_KEY=
ELEVENLABS_API_BASE_URL=https://api.elevenlabs.io

# Opcjonalnie: jeśli ustawione, nagłówek X-Benchmark-Key musi się zgadzać (POST /api/preview, /api/run, GET /api/model-catalog).
# Statyczny UI nie wysyła tego nagłówka — do testów z sekretem użyj curl / Postman albo zostaw puste na dev.
# BENCHMARK_SECRET=tajny-ciag
